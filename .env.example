# ---- Database (required) ----
# Any Postgres connection string. Neon is easiest (free tier works fine):
#   https://neon.tech  ->  create project  ->  copy the connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Admin (required) ----
# Secret bearer token that guards the /admin page + admin APIs
# (create/list/revoke read keys, hard-remove entries, manual health runs).
# Generate one with:  openssl rand -base64 32
ADMIN_TOKEN="change-me-to-a-long-random-string"

# ---- Cron (recommended in production) ----
# Secret the scheduled health check must present. On Vercel Cron this is sent
# automatically as the Authorization header. Generate with: openssl rand -base64 32
CRON_SECRET="change-me-to-a-long-random-string"

# ---- Read-key gating ----
# /api/sources always requires a valid per-app read key. When this is "true",
# /api/discovery/* also requires one
# (created on the /admin page). When unset/false, those endpoints are open.
# The public status page (/ and /api/status) is ALWAYS open regardless.
READ_KEYS_ENFORCED="true"

# ---- Credential encryption (required for account sources) ----
# Two independent base64-encoded 32-byte AES-256 keys. Generate each with:
#   openssl rand -base64 32
#
# POOL_ENCRYPTION_KEY  — at-rest key. Encrypts token/appId/etc. in the database so a
#   DB dump/backup leak exposes only ciphertext. Never leaves the server. Losing it
#   makes existing stored credentials unrecoverable (they'd need re-submitting).
POOL_ENCRYPTION_KEY="replace-with-base64-32-byte-key"
#
# POOL_CLIENT_KEY      — end-to-end key. /api/sources re-encrypts sensitive fields with
#   this, so anyone hitting the URL sees ciphertext, not tokens. The ArchiveTune app
#   ships the SAME value (as its POOL_CLIENT_KEY build field) and decrypts locally.
#   If blank or invalid, /api/sources fails closed with HTTP 503.
POOL_CLIENT_KEY="replace-with-a-different-base64-32-byte-key"
